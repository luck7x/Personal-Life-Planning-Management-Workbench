[Unit]
Description=Mingxintai FastAPI backend
After=network.target

[Service]
Type=simple
User=www-data
Group=www-data
WorkingDirectory=/opt/mingxintai
EnvironmentFile=/etc/mingxintai/backend.env
ExecStart=/opt/mingxintai/.venv/bin/uvicorn app.main:app --app-dir backend --host 127.0.0.1 --port 8000
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target
